# 复制本文件为 .env，然后按本机环境填写。

# ！！！这里填写自己的路径：MovieLens 解压后的数据目录
MOVIE_DATA_DIR=/Users/elemen/Downloads/moviedata-latest

# MySQL 配置。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=movie_analysis
MYSQL_CONNECTOR_JAR=lib/mysql-connector-j-8.4.0.jar

# 任务三 Streaming 工作目录。
MOVIE_STREAMING_DIR=~/movie_streaming
STREAMING_BATCH_NUM=10
STREAMING_BATCH_INTERVAL=10
STREAMING_FEED_INTERVAL=15
STREAMING_TOP_N=5
STREAMING_MIN_RATING_COUNT=50
# 可选：不填会在每次 make task3-stream 时自动生成。
# STREAMING_RUN_ID=demo-001
# 任务二默认直接读取 SQL 备份，不需要启动 MySQL
TASK2_DATA_SOURCE=sql_dump
TASK2_SQL_DUMP=sql/db_backup.sql
TASK2_TOP_N=8
